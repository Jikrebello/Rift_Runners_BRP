# ===== UNITY SPECIFIC =====
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Pp]ackages/*/
[Assets]/StreamingAssets/SteamworksManaged.dll

# Prevent uploading auto-generated .csproj and .sln files
*.csproj
*.sln
*.unityproj
*.userprefs

# Avoid uploading user-specific settings and logs
*.pidb
*.suo
*.svd
*.pdb
*.opendb
*.VC.db
*.tmp
*.temp
*.log
*.stackdump

# Avoid version control metadata
.vscode/
.idea/
*.iml

# Ignore Unity crash logs and exception logs
CrashReports/
UnityShaderCache/

# ===== GIT SPECIFIC =====
.DS_Store
Thumbs.db
*.bak
*.swp
*.swo

# Ignore Visual Studio and Rider IDE settings
.vs/
*.csproj.user
*.sln*
*.suo
*.cache
*.asset

# Ignore JetBrains Rider files
.idea/
*.iml

# Ignore macOS system files
.DS_Store

# Ignore Windows system files
Thumbs.db
